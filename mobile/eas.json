{
  "cli": {
    "version": ">= 16.27.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://cognivia-api-xgsl.onrender.com/api",
        "EXPO_PUBLIC_WEB_URL": "https://cogniviahq.vercel.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}