APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Comma-separated proxy IPs/CIDRs to trust for X-Forwarded-* headers, or '*'
# when the app is only reachable through a platform proxy (e.g. Render).
# Defaults to the Docker bridge range used by the local nginx container.
TRUSTED_PROXIES=172.16.0.0/12

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

ADMIN_SEEDER_EMAIL=
ADMIN_SEEDER_PASSWORD=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue backend.
#   sync     : default — jobs run inline in the request. No worker needed, so
#              queued mail still sends out of the box. Correct for the free tier.
#   database : async via the existing MySQL (free, no extra service). Requires
#              the worker: `docker compose --profile worker up -d`.
#   redis    : async + shared across instances; the path before scaling out.
#              Set REDIS_* below and run the worker profile.
QUEUE_CONNECTION=sync

# Cache / session backends.
#   database : default, zero extra infrastructure — fine for a single instance.
#   redis    : shared across instances and REQUIRED before scaling out, so the
#              login rate-limiter and sessions live in a store every instance
#              can see. Set CACHE_STORE=redis and SESSION_DRIVER=redis together.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# REDIS_CLIENT=predis is the pure-PHP client and needs no PECL extension, so it
# works in every environment out of the box. Switch to phpredis only where the
# extension is installed and the extra throughput is needed.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail. Three supported setups:
#   - log    : writes emails to the log (default for local dev)
#   - smtp   : any SMTP relay (locally, Gmail SMTP on 587 works fine)
#   - gmail  : Gmail API over HTTPS — use this on hosts that block SMTP ports
#              (e.g. Render free tier). Run `php artisan gmail:authorize` once
#              to obtain GMAIL_REFRESH_TOKEN. MAIL_FROM_ADDRESS must be the
#              authorized Gmail account.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_TIMEOUT=10
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Gmail API transport (MAIL_MAILER=gmail). From the Google Cloud OAuth client.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# JWT — generate with: openssl rand -base64 64 | tr -d '\n='
JWT_SECRET=

# Sentry error monitoring. Leave blank to disable (fully no-op). Set to the DSN
# from a free sentry.io project to capture unhandled exceptions in production.
# traces_sample_rate is kept at 0 so only errors are sent — performance tracing
# would add overhead that the free instance can't spare.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# OpenRouter — server-side AI proxy for flashcard generation & answer checking.
# Required in every environment (local, Render, etc.); the key never reaches the
# mobile bundle. Get a key at https://openrouter.ai/keys.
# OPENROUTER_MODEL must be a model that currently exists on OpenRouter — verify
# at https://openrouter.ai/api/v1/models. ":free" models are rate-limited and
# unreliable for production; a cheap paid model (e.g. gemini-2.5-flash-lite) is
# recommended. Omitting OPENROUTER_MODEL falls back to the config default.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Async flashcard generation. When true, /api/flashcards/generate queues the AI
# call and returns 202 + request_id; the result arrives over the private
# user.{id} broadcast channel. REQUIRES a running queue worker AND a real
# broadcast driver (pusher/soketi) — leave false with QUEUE_CONNECTION=sync or
# BROADCAST_CONNECTION=log, or the result can never reach the client. See
# SCALING.md. Default false = synchronous 200 response (always safe).
FLASHCARD_GENERATION_ASYNC=false

# CORS allowed origins (config/cors.php). Both run with credentials enabled.
#   FRONTEND_URL  : the production web app origin, e.g. https://cognivia.vercel.app
#   DEV_TUNNEL_URL: optional per-developer tunnel origin (e.g. an ngrok URL).
#                   Leave unset in production — do not add untrusted origins here.
FRONTEND_URL=
DEV_TUNNEL_URL=
